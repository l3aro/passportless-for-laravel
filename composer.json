{
    "name": "l3aro/passportless-for-laravel",
    "description": "Secure token-based authentication for first-party Laravel APIs",
    "keywords": [
        "l3aro",
        "laravel",
        "passportless"
    ],
    "homepage": "https://github.com/l3aro/passportless-for-laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "l3aro",
            "email": "dgbao1340@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0.0||^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "l3aro\\Passportless\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "l3aro\\Passportless\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "l3aro\\Passportless\\PassportlessServiceProvider"
            ],
            "aliases": {
                "Passportless": "l3aro\\Passportless\\Facades\\Passportless"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
